{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":approveMajorUpdates",
    ":label(dependencies)",
    ":semanticCommitType(chore)",
    ":automergeRequireAllStatusChecks"
  ],
  "commitMessagePrefix": "chore(all): ",
  "commitMessageAction": "update",
  "commitBody": "Signed-off-by: Renovate Bot <bot@renovateapp.com>",
  "platformAutomerge": true,
  "automergeType": "branch",
  "automerge": true,
  "automergeStrategy": "squash",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 50,
  "ignoreTests": false,
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "npm": {
    "minimumReleaseAge": "3 days"
  },
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": true,
    "minimumReleaseAge": "0 days"
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track act version in Makefile",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": ["ACT_VERSION\\s*:=\\s*(?<currentValue>.*?)\\n"],
      "depNameTemplate": "nektos/act",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Track hadolint version in Makefile",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": ["HADOLINT_VERSION\\s*:=\\s*(?<currentValue>.*?)\\n"],
      "depNameTemplate": "hadolint/hadolint",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Track nvm version in Makefile",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": ["NVM_VERSION\\s*:=\\s*(?<currentValue>.*?)\\n"],
      "depNameTemplate": "nvm-sh/nvm",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Track Node.js major version in Makefile",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": ["NODE_VERSION\\s*:=\\s*(?<currentValue>\\d+)\\n"],
      "depNameTemplate": "node",
      "datasourceTemplate": "node-version",
      "versioningTemplate": "node"
    },
    {
      "customType": "regex",
      "description": "Track pnpm version in GitHub Actions",
      "managerFilePatterns": ["/^\\.github/workflows/[^/]+\\.yml$/"],
      "matchStrings": ["uses:\\s*pnpm/action-setup[^\\n]*\\n\\s*with:\\n\\s*version:\\s*(?<currentValue>\\d+)"],
      "depNameTemplate": "pnpm",
      "datasourceTemplate": "npm",
      "versioningTemplate": "npm"
    },
    {
      "customType": "regex",
      "description": "Track MongoDB service image in GitHub Actions",
      "managerFilePatterns": ["/^\\.github/workflows/[^/]+\\.yml$/"],
      "matchStrings": ["image:\\s*mongo:(?<currentValue>[^@\\s]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"],
      "depNameTemplate": "mongo",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "description": "Wait 3 days before automerging major updates",
      "matchUpdateTypes": ["major"],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Group GitHub Actions into one PR",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Group devDependencies non-major updates",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "dev-dependencies",
      "automerge": true
    },
    {
      "description": "Group Makefile tool versions",
      "matchManagers": ["custom.regex"],
      "groupName": "Makefile tools",
      "automerge": true
    },
    {
      "description": "Group type definitions",
      "matchPackageNames": ["/^@types\\//"],
      "groupName": "type-definitions",
      "automerge": true
    }
  ]
}
